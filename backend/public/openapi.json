										"type": "array",
										"items": { "type": "string" },
										"description": "Liste de noms de fichiers dans /uploads"
									},
									"urls": {
										"type": "array",
										"items": { "type": "string" },
										"description": "Liste d'URLs commençant par /uploads/"
									},
									"filename": { "type": "string" },
									"url": { "type": "string" }
								}
							},
							"examples": {
								"singleFilename": {
									"summary": "Un seul fichier",
									"value": {
										"filename": "1692971234-a1b2c3d4.jpg"
									}
								},
								"multipleUrls": {
									"summary": "Plusieurs URLs",
									"value": {
										"urls": [
											"/uploads/1692971234-a1b2c3d4.jpg",
											"/uploads/1692971299-ffeedd.png"
										]
									}
								}
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "Tous supprimés",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"ok": { "type": "boolean" },
										"deleted": {
											"type": "array",
											"items": { "type": "string" }
										},
										"not_found": {
											"type": "array",
											"items": { "type": "string" }
										},
										"errors": {
											"type": "array",
											"items": {
												"type": "object",
												"properties": {
													"filename": {
														"type": "string"
													},
													"error": {
														"type": "string"
													}
												}
											}
										},
										"results": {
											"type": "array",
											"items": { "type": "object" }
										}
									}
								}
							}
						}
					},
					"207": {
						"description": "Partiellement supprimés (Multi-Status)",
						"content": {
							"application/json": {
								"schema": { "type": "object" }
							}
						}
					},
					"400": {
						"description": "Requête invalide (aucun élément fourni)",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					},
					"401": {
						"description": "Authentification requise",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					},
					"403": {
						"description": "Interdit (owner ou admin seulement)",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		}
