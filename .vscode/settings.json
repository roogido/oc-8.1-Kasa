{
	// ----------------------------
	// EDITOR - BASIC BEHAVIOR
	// ----------------------------
	// Disable hover popup (tooltip)
	"editor.hover.enabled": "off",
	// Delay before hover shows
	"editor.hover.delay": 1200,

	// Indentation
	"editor.tabSize": 4,
	"editor.insertSpaces": true,
	"editor.detectIndentation": false,

	// Disable minimap (less visual noise)
	"editor.minimap.enabled": false,
	// Disable code lens (top inline info)
	"editor.codeLens": false,

	// Disable smart occurrences highlight
	"editor.occurrencesHighlight": "multiFile",
	// Highlight selected word occurrences
	"editor.selectionHighlight": true,

	// Show bracket match near cursor
	"editor.matchBrackets": "near",
	// Show bracket guides
	"editor.guides.bracketPairs": false,

	// Show spaces only when selecting text
	"editor.renderWhitespace": "selection",
	"editor.renderControlCharacters": false,

	// Disable suggestions icons/lightbulb
	"editor.lightbulb.enabled": "off",
	"editor.inlayHints.enabled": "off",

	// Enable inline suggestions (Copilot / AI)
	"editor.inlineSuggest.enabled": true,

	// Auto format settings
	"editor.formatOnSave": true,
	"editor.formatOnPaste": false,
	"editor.formatOnType": false,

	// Disable word wrap
	"editor.wordWrap": "off",
	"editor.smoothScrolling": false,

	// ----------------------------
	// WORKBENCH - UI BEHAVIOR
	// ----------------------------
	// Open files in full tab (no preview)
	"workbench.editor.enablePreview": false,
	// No startup page
	"workbench.startupEditor": "none",
	// Tree indentation size
	"workbench.tree.indent": 16,
	"workbench.list.smoothScrolling": false,

	// ----------------------------
	// EXPLORER
	// ----------------------------
	// Confirm delete and drag actions
	"explorer.confirmDelete": true,
	"explorer.confirmDragAndDrop": true,

	// ----------------------------
	// FILES
	// ----------------------------
	// Auto save after delay
	"files.autoSave": "afterDelay",
	// Clean code on save
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.eol": "\n",

	// ----------------------------
	// NAVIGATION
	// ----------------------------
	// Show breadcrumbs (file path)
	"breadcrumbs.enabled": true,

	// ----------------------------
	// GIT
	// ----------------------------
	// Show diff in gutter
	"scm.diffDecorations": "gutter",
	// Show git status decorations
	"git.decorations.enabled": true,

	// ----------------------------
	// JAVASCRIPT / TYPESCRIPT
	// ----------------------------
	// Auto update imports on file move
	"js/ts.updateImportsOnFileMove.enabled": "always",

	// ----------------------------
	// EXTENSIONS - DISABLED FEATURES
	// ----------------------------
	// Disable GitHD inline blame (clean UI)
	"githd.blameView.enabled": "disabled",

	// ----------------------------
	// SEARCH / EXCLUDE
	// ----------------------------
	// Exclude heavy folders from search
	"search.exclude": {
		"**/.next": true,
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/coverage": true
	},

	// Hide folders in explorer
	"files.exclude": {
		"**/.next": true,
		"**/dist": true,
		"**/build": true,
		"**/coverage": true
	}
}
